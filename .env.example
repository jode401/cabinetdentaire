# منفذ الخادم
PORT=3000

# مسار قاعدة بيانات SQLite
DB_PATH=maher.db

# مفتاح الإدارة لعرض قائمة المسجّلين عبر GET /api/registrations
ADMIN_KEY=change-this-secret-key

# إعدادات البريد (اختيارية — احذفها إن لم ترد إرسال بريد تأكيد)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=ملتقى ماهر <no-reply@maher.example>
